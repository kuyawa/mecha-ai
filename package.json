{
  "name": "mecha-ai",
  "version": "1.0.2",
  "type": "module",
  "description": "Mecha AI - AI coding assistant using DeepSeek API",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./assistant": "./dist/assistant.js",
    "./config": "./dist/config.js",
    "./tools": "./dist/tools/index.js"
  },
  "bin": {
    "mecha": "./dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "node --watch src/index.js",
    "test": "node src/test.js",
    "preview": "node dist/cli.js preview",
    "build": "node build.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "deepseek",
    "coding-assistant",
    "automation",
    "code-generation"
  ],
  "author": "deepseek + kuyawa",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.77.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "tiktoken": "^1.0.16",
    "diff-match-patch": "^1.0.5",
    "ora": "^8.1.0",
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kuyawa/mecha-ai.git"
  },
  "bugs": {
    "url": "https://github.com/kuyawa/mecha-ai/issues"
  },
  "homepage": "https://github.com/kuyawa/mecha-ai#readme"
}
